"""{{ server.display_name }} MCP Server - Security utilities for write protection"""

from contextvars import ContextVar
from functools import wraps
from typing import Any, Callable

import structlog

from {{ server.package_name }}.config import MCPSettings

logger = structlog.get_logger(__name__)

_mcp_settings_var: ContextVar[MCPSettings | None] = ContextVar("mcp_settings", default=None)


def init_security(settings: MCPSettings) -> None:
    """Initialize security module with settings"""
    _mcp_settings_var.set(settings)
    logger.info(
        "Security initialized",
        allow_write=settings.allow_write,
        mode="READ_ONLY" if not settings.allow_write else "READ_WRITE",
    )


def is_write_allowed() -> bool:
    """Check if write operations are allowed"""
    settings = _mcp_settings_var.get()
    if settings is None:
        logger.warning("Security not initialized, defaulting to read-only")
        return False
    return settings.allow_write


def write_protected(func: Callable) -> Callable:
    """
    Decorator to protect write operations.
    If write is not allowed, raises an error.
    """
    @wraps(func)
    async def wrapper(*args, **kwargs) -> Any:
        if not is_write_allowed():
            logger.warning(
                "Write operation blocked",
                operation=func.__name__,
                mode="READ_ONLY",
            )
            raise PermissionError(
                f"Write operations are disabled. "
                f"Set {{ server.env_prefix }}_ALLOW_WRITE=true to enable {func.__name__}."
            )
        return await func(*args, **kwargs)
    return wrapper