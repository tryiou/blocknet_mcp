# RPC Configuration (shared by all services)
RPC_HOST=localhost
RPC_PORT=41414
RPC_USER=your_rpc_user
RPC_PASSWORD=your_rpc_password
RPC_TIMEOUT=30

# Blockchain data directory (volume mount for blocknet-core container)
BLOCKNET_CHAINDIR=~/.blocknet/

# MCP Server Configuration
MCP_LOG_LEVEL=INFO
MCP_ALLOW_WRITE=false
MCP_TRANSPORT=stdio    # Transport mode: stdio or http
MCP_PORT=8080          # Port for HTTP transport (only used if MCP_TRANSPORT=http)
MCP_HOST=0.0.0.0     # 0.0.0.0 to allow connection from other containers, 127.0.0.1 only allow localhost connection
