# Blockchain data directory (REQUIRED)
# Credentials are read from blocknet.conf (rpcuser, rpcpassword)
# Port is also auto-detected from blocknet.conf if present
BLOCKNET_CHAINDIR=~/.blocknet/

# RPC Configuration
RPC_HOST=localhost
RPC_PORT=41414
RPC_TIMEOUT=30

# XBridge MCP Server Configuration
XBRIDGE_MCP_SERVER_NAME=XBridge MCP Server
XBRIDGE_MCP_LOG_LEVEL=INFO
XBRIDGE_MCP_ALLOW_WRITE=false
XBRIDGE_MCP_TRANSPORT=http
XBRIDGE_MCP_PORT=8081
XBRIDGE_MCP_HOST=0.0.0.0

# XRouter MCP Server Configuration
XROUTER_MCP_SERVER_NAME=XRouter MCP Server
XROUTER_MCP_LOG_LEVEL=INFO
XROUTER_MCP_ALLOW_WRITE=false
XROUTER_MCP_TRANSPORT=http
XROUTER_MCP_PORT=8082
XROUTER_MCP_HOST=0.0.0.0
